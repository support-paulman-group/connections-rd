---
import "../styles/global.css";
import HomePage from "../../paginas/home/HomePage";
import { siteMeta } from "../../herramientas/content/home-blocks";
import { siteContact } from "../../herramientas/content/site-contact";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteMeta.title}</title>
    <meta name="description" content={siteMeta.description} />
    <meta name="keywords" content={siteMeta.keywords} />
    <meta property="og:title" content={siteMeta.title} />
    <meta property="og:description" content={siteMeta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={siteMeta.ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "RealEstateAgent",
      name: "Connections RD",
      description: siteMeta.description,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Cabarete",
        addressRegion: "Puerto Plata",
        addressCountry: "DO",
      },
      telephone: siteContact.phone,
      email: siteContact.email,
    })} />
  </head>
  <body>
    <HomePage client:load />
    <script>
      (() => {
        let activeIndex = 0;

        const getModal = () => document.querySelector("[data-experience-gallery-modal]");
        const getSlides = () => Array.from(document.querySelectorAll("[data-gallery-slide]"));

        const setActiveSlide = (index) => {
          const slides = getSlides();
          if (slides.length === 0) return;
          activeIndex = (index + slides.length) % slides.length;
          slides.forEach((slide, slideIndex) => {
            const isActive = slideIndex === activeIndex;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", String(!isActive));
          });
          const count = document.querySelector(".experience-gallery-modal__count strong");
          if (count) count.textContent = String(activeIndex + 1).padStart(2, "0");
        };

        const openGallery = (index) => {
          const modal = getModal();
          if (!modal) return;
          setActiveSlide(index);
          modal.classList.add("is-open");
          document.body.classList.add("experience-gallery-modal-open");
        };

        const closeGallery = () => {
          const modal = getModal();
          if (!modal) return;
          modal.classList.remove("is-open");
          document.body.classList.remove("experience-gallery-modal-open");
        };

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const openButton = target.closest("[data-gallery-open]");
          if (openButton instanceof HTMLElement) {
            openGallery(Number(openButton.dataset.galleryOpen || 0));
            return;
          }

          if (target.closest("[data-gallery-close]")) closeGallery();
          if (target.closest("[data-gallery-next]")) setActiveSlide(activeIndex + 1);
          if (target.closest("[data-gallery-previous]")) setActiveSlide(activeIndex - 1);
        });

        document.addEventListener("keydown", (event) => {
          const modal = getModal();
          if (!modal?.classList.contains("is-open")) return;
          if (event.key === "Escape") closeGallery();
          if (event.key === "ArrowRight") setActiveSlide(activeIndex + 1);
          if (event.key === "ArrowLeft") setActiveSlide(activeIndex - 1);
        });
      })();
    </script>
  </body>
</html>
