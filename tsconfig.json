{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@componentes/*": ["componentes/*"],
      "@herramientas/*": ["herramientas/*"],
      "@paginas/*": ["paginas/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"]
}
